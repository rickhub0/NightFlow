{
  "manifest_version": 3,
  "name": "NightFlow Companion",
  "version": "1.0.0",
  "description": "Real-time task sync and reminders for NightFlow.",
  "permissions": ["notifications", "storage", "alarms"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "128": "icon128.png"
  }
}
